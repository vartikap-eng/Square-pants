OPENAI_API_KEY=sk-...
DATABASE_URL=sqlite:///./conference_leads.db
FRONTEND_URL=http://localhost:5173

# Gmail SMTP — actual email sending
# Step 1: Enable 2FA on your Gmail account
# Step 2: Go to myaccount.google.com → Security → App Passwords → create one
# Step 3: Use that 16-char app password below (NOT your Gmail login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=Sales Team <your-email@gmail.com>

# Gmail IMAP — reply detection (same credentials as above)
IMAP_HOST=imap.gmail.com
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=xxxx-xxxx-xxxx-xxxx
